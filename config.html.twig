<script>
function testConnection() {
    const btn = event.target.closest('button');
    const originalText = btn.innerHTML;
    
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Testing...';
    
    // FOSSBilling will handle the actual test via AJAX
    alert('<?= __('Connection test will be executed when you save the configuration.') ?>');
    
    setTimeout(() => {
        btn.disabled = false;
        btn.innerHTML = originalText;
    }, 2000);
}
</script>

